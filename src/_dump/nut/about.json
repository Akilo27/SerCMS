        "info": [],
        "type": "information"
      },
      "step_description_2": {
        "field": "Разработка авторских смесей: Создание уникальных миксов (например, \"Энергия утра\" — миндаль, клюква, темный шоколад; \"Восточный базар\" — финики, грецкий орех, имбирь).\n\n",
        "info": [],
        "type": "information"
